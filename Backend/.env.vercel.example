# Template Environment Variables untuk Vercel
#   cp .env.vercel.example .env.vercel
#   isi nilai → paste ke Vercel Dashboard → Settings → Environment Variables
# Jangan commit .env.vercel (ada di .gitignore)

NODE_ENV=production

DATABASE_USER=postgres.xxxxx
DATABASE_PASSWORD=your_supabase_password
DATABASE_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres

JWT_SECRET=string_acak_panjang_khusus_production
