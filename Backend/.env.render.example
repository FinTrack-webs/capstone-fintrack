# Template Environment Variables untuk Render
# Cara pakai:
#   1. Salin file ini: cp .env.render.example .env.render
#   2. Isi nilai dari Supabase dashboard (sama seperti .env lokal, kecuali JWT_SECRET)
#   3. Di Render → Environment Variables → klik "Add from .env"
#   4. Paste isi .env.render (tanpa baris komentar #)
#
# PENTING: Jangan commit .env.render ke Git (sudah di .gitignore)

NODE_ENV=production
HOST=0.0.0.0

DATABASE_USER=postgres.xxxxx
DATABASE_PASSWORD=your_supabase_password
DATABASE_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres

JWT_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG_ATAU_KLIK_GENERATE_DI_RENDER
