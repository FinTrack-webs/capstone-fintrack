{
  "info": {
    "name": "FinTrack API",
    "_postman_id": "fintrack-api-collection",
    "description": "Integration test collection untuk FinTrack Backend API.\nAlur: Register → Login → Categories → Transactions → Dashboard → Logout",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "refreshTokenForLogout", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "testEmail", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "transactionId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ping"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has Pong', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Pong!');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"testuser_placeholder@fintrack.test\", \"password\": \"password123\"}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = 'testuser_' + Date.now() + '@fintrack.test';",
                  "pm.collectionVariables.set('testEmail', email);",
                  "pm.request.body.raw = JSON.stringify({ email: email, password: 'password123' });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response success', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('success');",
                  "  pm.expect(body.data).to.have.property('id');",
                  "  pm.expect(body.data).to.have.property('email');",
                  "  pm.collectionVariables.set('userId', body.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - Duplicate Email (409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"password123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"password123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has tokens', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('success');",
                  "  pm.expect(body.data).to.have.property('accessToken');",
                  "  pm.expect(body.data).to.have.property('refreshToken');",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "  // Simpan copy khusus untuk nanti dipakai saat logout",
                  "  pm.collectionVariables.set('refreshTokenForLogout', body.data.refreshToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Wrong Password (401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"wrongpassword\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has new accessToken', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('accessToken');",
                  "  // Update accessToken dengan yang baru",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  // refreshToken tetap tidak berubah (tidak ada rotasi)",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.be.an('array');",
                  "  if (body.data.length > 0) {",
                  "    pm.collectionVariables.set('categoryId', body.data[0].id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test Category Newman\", \"type\": \"expense\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Category created', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('id');",
                  "  pm.collectionVariables.set('categoryId', body.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Category found', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('id');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/categories/{{categoryId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test Category Updated\", \"type\": \"expense\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction (with category)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 50000, \"description\": \"Beli nasi goreng di warung\", \"date\": \"2026-05-17\"}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Inject categoryId ke body secara dinamis",
                  "const categoryId = pm.collectionVariables.get('categoryId');",
                  "pm.request.body.raw = JSON.stringify({",
                  "  category_id: categoryId,",
                  "  amount: 50000,",
                  "  description: 'Beli nasi goreng di warung',",
                  "  date: '2026-05-17'",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Transaction created', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('id');",
                  "  pm.collectionVariables.set('transactionId', body.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Transaction (without category - AI Mock)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 25000, \"description\": \"Bayar grab ke kantor\", \"date\": \"2026-05-17\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Transaction created with pending status', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('id');",
                  "  pm.expect(body.data.classification_status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Transaction By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions/{{transactionId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Transaction found', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('id');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/transactions/{{transactionId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 75000, \"description\": \"Beli nasi goreng special\", \"date\": \"2026-05-17\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/transactions/{{transactionId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has summary fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.have.property('totalIncome');",
                  "  pm.expect(body.data).to.have.property('totalExpense');",
                  "  pm.expect(body.data).to.have.property('balance');",
                  "  pm.expect(body.data).to.have.property('breakdown');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Dashboard - No Auth (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth - Logout",
      "item": [
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refreshTokenForLogout}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh After Logout (401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refreshTokenForLogout}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Token revoked', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "Re-Login for Cleanup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"password123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Re-login sukses', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.data) {",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Test Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/categories/{{categoryId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Category cleanup', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
